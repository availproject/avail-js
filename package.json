{
  "name": "avail-js-sdk",
  "version": "0.6.0",
  "description": "Avail library of functions to interact with blockchain and manipulate transactions",
  "main": "./build/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon src/index.ts",
    "build": "rimraf build && tsc && node ./_scripts/build.mjs",
    "build-linux": "rm -rf build && tsc && node ./_scripts/build.mjs",
    "publish-avail": "npm run lint && npm run format && npm run build && cd build && npm publish && cd ..",
    "publish-avail-linux": "npm run build-linux && cd build && npm publish --tag=beta && cd ..",
    "test": "npx jest --config jest.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:v2": "npm run typecheck",
    "format": "prettier --write .",
    "lint": "eslint ./src --ext .js,.ts",
    "lint-examples": "eslint ./examples/node-examples --ext .js,.ts"
  },
  "keywords": [
    "avail",
    "data",
    "blockchain",
    "substrate",
    "sdk",
    "typescript"
  ],
  "author": "Ghali Leouarz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/availproject/avail-js/issues/new/choose"
  },
  "homepage": "https://github.com/availproject/avail-js",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@polkadot/api": "^16.5.4",
    "tslog": "^4.10.2"
  },
  "resolutions": {
    "ws": ">=8.17.1"
  }
}
